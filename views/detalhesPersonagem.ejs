  const rollTotal = document.getElementById('rollTotal');

window.showRollResult = function(data) {
  let title = '';
  let message = '';
  let details = '';
  let total = 0;
  let isCritical = false;
  let isFumble = false;

  // Verifica se é um ataque (dados retornados pelo controller de inventário)
  if (data.ataque) {
    title = '⚔️ Ataque';
    message = `⚔️ ${data.arma_nome || 'Arma'}`;
    details = `Acerto: ${data.ataque.roll} + ${data.ataque.bonus} = ${data.ataque.total}${data.ataque.critico ? ' (CRÍTICO!)' : ''}\nDano: ${data.dano.rolagens.join(' + ')} = ${data.dano.total}`;
    total = data.dano.total;
    isCritical = data.ataque.critico;
    isFumble = false;
  } 
  // Verifica se é uma habilidade ou atributo (formato original)
  else if (data.habilidade) {
    title = `🎲 ${data.habilidade.nome}`;
    message = data.message;
    details = data.details;
    total = data.total;
    isCritical = data.isCritical;
    isFumble = data.isFumble;
  } 
  else {
    // Fallback para o formato antigo (atributos)
    title = data.tipo === 'atributo' ? `🎲 Rolagem de ${data.atributo.toUpperCase()}` : `🎲 ${data.habilidade?.nome || 'Rolagem'}`;
    message = data.message;
    details = data.details;
    total = data.total;
    isCritical = data.isCritical;
    isFumble = data.isFumble;
  }

  rollTitle.innerText = title;
  rollMessage.innerText = message;
  rollDetails.innerText = details;
  rollTotal.innerText = total;
  rollTotal.classList.remove('critical', 'fumble');
  if (isCritical) rollTotal.classList.add('critical');
  if (isFumble) rollTotal.classList.add('fumble');
  rollModal.style.display = 'flex';
};

  function closeRollModal() {
    rollModal.style.display = 'none';
  }

  document.querySelectorAll('.roll-close, .roll-close-btn').forEach(el => {
    el.addEventListener('click', closeRollModal);
  });
  window.addEventListener('click', (e) => {
    if (e.target === rollModal) closeRollModal();
  });

  // ======================
  // ATRIBUTOS (AUMENTAR/DIMINUIR)
  // ======================
  const botoesAtributo = document.querySelectorAll('.btn-atributo[data-op]');
  console.log('Botões de atributo encontrados:', botoesAtributo.length);
  botoesAtributo.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const atributo = btn.getAttribute('data-atributo');
      const operacao = btn.getAttribute('data-op');
      try {
        const response = await fetch(`/personagens/${idPersonagem}/atributo/${atributo}/${operacao}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        if (response.ok && data.ok) {
          const attrDiv = document.querySelector(`.attr[data-atributo="${atributo}"]`);
          if (attrDiv) {
            const valorSpan = attrDiv.querySelector('.attr-valor');
            if (valorSpan) valorSpan.innerText = data.novoValor;
          }
          const vidaAtualSpan = document.querySelector('.vida-atual-editable');
          const vidaMaxSpan = document.querySelector('.vida-max-editable');
          if (vidaAtualSpan) {
            vidaAtualSpan.innerText = data.vida_atual;
            vidaAtualSpan.setAttribute('data-max', data.vida_max);
          }
          if (vidaMaxSpan) vidaMaxSpan.innerText = data.vida_max;
          const barraVida = document.querySelector('.barra-vida');
          if (barraVida) barraVida.style.width = `${(data.vida_atual / data.vida_max) * 100}%`;
          const sanidadeAtualSpan = document.querySelector('.sanidade-atual-editable');
          const sanidadeMaxSpan = document.querySelector('.sanidade-max-editable');
          if (sanidadeAtualSpan) {
            sanidadeAtualSpan.innerText = data.sanidade_atual;
            sanidadeAtualSpan.setAttribute('data-max', data.sanidade_max);
          }
          if (sanidadeMaxSpan) sanidadeMaxSpan.innerText = data.sanidade_max;
          const barraSanidade = document.querySelector('.barra-sanidade');
          if (barraSanidade) barraSanidade.style.width = `${(data.sanidade_atual / data.sanidade_max) * 100}%`;
          const pontosSpan = document.querySelector('#pontos-atributo-disponiveis');
          if (pontosSpan) pontosSpan.innerText = data.pontos_disponiveis_atributo;
          if (data.ca) document.getElementById('caValor').innerText = data.ca;
          else if (atributo === 'agilidade') atualizarCA();
          const todosAumentar = document.querySelectorAll('.btn-atributo[data-op="aumentar"]');
          if (data.pontos_disponiveis_atributo <= 0) {
            todosAumentar.forEach(btn => btn.disabled = true);
          } else {
            todosAumentar.forEach(btn => btn.disabled = false);
          }
          if (attrDiv) {
            const btnDiminuir = attrDiv.querySelector('.btn-atributo[data-op="diminuir"]');
            if (btnDiminuir) btnDiminuir.disabled = (data.novoValor <= 1);
          }
        } else {
          alert(data.erro || 'Erro ao alterar atributo');
        }
      } catch (err) {
        console.error('Fetch error:', err);
        alert('Erro de conexão com o servidor');
      }
    });
  });

