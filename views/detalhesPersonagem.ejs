    const listaDiv = document.getElementById('listaItensBiblioteca');
    if (!listaDiv) return;
    
    const itensFiltrados = tipo ? todosItensBiblioteca.filter(item => item.tipo === tipo) : todosItensBiblioteca;
    listaDiv.innerHTML = '';
    
    if (itensFiltrados.length === 0) {
      listaDiv.innerHTML = '<p>Nenhum item encontrado.</p>';
      return;
    }
    
    itensFiltrados.forEach(item => {
      const btn = document.createElement('button');
      btn.className = 'btn-seta';
      btn.style.margin = '2px';
      btn.innerText = `${item.nome} (${item.tipo})`;
      btn.onclick = async () => {
        try {
          const response = await fetch(`/personagens/${idPersonagem}/inventario/adicionar`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_personagem: idPersonagem, id_item_biblioteca: item.id })
          });
          const data = await response.json();
          if (response.ok && data.ok) {
            document.getElementById('modalAddItem').style.display = 'none';
            carregarInventario(); // recarrega inventário
            if (item.tipo === 'protecao') await recalcularCA();
          } else {
            alert(data.erro || 'Erro ao adicionar item');
          }
        } catch (err) {
          console.error(err);
          alert('Erro de conexão ao adicionar item');
        }
      };
      listaDiv.appendChild(btn);
    });
  }

  // Abrir modal 
  const btnAddItem = document.getElementById('btnAdicionarItem');
  if (btnAddItem) {
    btnAddItem.addEventListener('click', async () => {
      const modalAdd = document.getElementById('modalAddItem');
      modalAdd.style.display = 'block';
      
      if (todosItensBiblioteca.length === 0) {
        const listaDiv = document.getElementById('listaItensBiblioteca');
        listaDiv.innerHTML = 'Carregando...';
        try {
          const res = await fetch('/itens/biblioteca');
          const data = await res.json();
          todosItensBiblioteca = [...data.gerais, ...data.pessoais];
          exibirItensFiltrados(''); // exibe todos inicialmente
        } catch (err) {
          console.error(err);
          listaDiv.innerHTML = '<p>Erro ao carregar itens.</p>';
        }
      } else {
        // Já tem cache: exibe com o filtro atual
        const filtro = document.getElementById('tipoItemFiltro').value;
        exibirItensFiltrados(filtro);
      }
    });
  }

  // Evento de mudança do filtro 
  const filtroSelect = document.getElementById('tipoItemFiltro');
  if (filtroSelect) {
    filtroSelect.addEventListener('change', (e) => {
      if (todosItensBiblioteca.length) {
        exibirItensFiltrados(e.target.value);
      }
    });
  }

  // ======================
  // FUNÇÕES EXISTENTES DO INVENTÁRIO 
  // ======================
  async function carregarInventario() {
    try {
      const res = await fetch(`/personagens/${idPersonagem}/inventario`);
      const itens = await res.json();
      const container = document.getElementById('listaInventario');
      if (!container) return;
      container.innerHTML = '';
      for (const item of itens) {
        const div = document.createElement('div');
        div.className = `item-card ${item.esta_equipado ? 'item-equipado' : ''} item-tipo-${item.tipo}`;
        div.innerHTML = `
          <div style="display:flex; justify-content:space-between;">
            <strong>${item.nome_personalizado || item.nome}</strong>
            <span>${item.tipo}</span>
          </div>
          <p>${item.descricao || ''}</p>
          ${item.tipo === 'arma' ? `<p><strong>Dano:</strong> ${item.dado_dano} | <strong>Crítico:</strong> ${item.margem_critico}/${item.multiplicador_critico}x</p>` : ''}
          ${item.tipo === 'protecao' ? `<p><strong>CA:</strong> +${item.bonus_ca}</p>` : ''}
          ${item.tipo === 'anomalo' ? `<p><strong>Usos:</strong> ${item.usos_restantes !== null ? item.usos_restantes : item.usos_maximos} / ${item.usos_maximos || '∞'}</p>` : ''}
          <div style="display:flex; gap:5px; margin-top:8px;">
            ${item.tipo === 'arma' ? `<button class="btn-ataque-arma btn-seta" data-id="${item.id}">⚔️ Atacar</button>` : ''}
            ${item.tipo !== 'arma' && item.tipo !== 'protecao' ? `<button class="btn-usar-item btn-seta" data-id="${item.id}">🎲 Usar</button>` : ''}
            ${item.tipo === 'protecao' || item.tipo === 'arma' ? 
              `<button class="btn-equipar-item btn-seta" data-id="${item.id}">${item.esta_equipado ? '🔓 Desequipar' : '🔒 Equipar'}</button>` : ''}
            <button class="btn-remover-item btn-seta" data-id="${item.id}">🗑️ Remover</button>
          </div>
          <div id="mods-${item.id}" class="mods-lista" style="margin-top:5px; font-size:12px;"></div>
        `;
        container.appendChild(div);
        await carregarModificacoesItem(item.id);
      }
    } catch(err) { console.error(err); }
  }

  async function carregarModificacoesItem(idItemPersonagem) {
    try {
      const res = await fetch(`/personagens/${idPersonagem}/inventario/${idItemPersonagem}/modificacoes`);
      const mods = await res.json();
      const divMods = document.getElementById(`mods-${idItemPersonagem}`);
      if (divMods && mods.length) {
        divMods.innerHTML = `<strong>Modificações:</strong> ${mods.map(m => m.nome).join(', ')}`;
      }
    } catch(err) { console.error(err); }
  }

  document.addEventListener('click', async (e) => {
    const target = e.target;
    const id = target.getAttribute('data-id');
    if (target.classList.contains('btn-equipar-item')) {
  const estaEquipado = target.innerText.includes('Desequipar'); // se o texto é "Desequipar", está equipado
  const novoEstado = !estaEquipado;
  await fetch(`/personagens/${idPersonagem}/inventario/${id}/equipar`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ equipado: novoEstado })
  });
  carregarInventario();
  await recalcularCA();
}
    if (target.classList.contains('btn-remover-item')) {
      if (!confirm('Remover item do inventário?')) return;
      await fetch(`/personagens/${idPersonagem}/inventario/${id}`, { method: 'DELETE' });
      carregarInventario();
      await recalcularCA();
    }
    if (target.classList.contains('btn-ataque-arma')) {
  const id = target.getAttribute('data-id');
  try {
    const response = await fetch(`/personagens/${idPersonagem}/inventario/${id}/atacar`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    const data = await response.json();
    if (response.ok && data.ok) {
      const resultado = {
        message: `⚔️ Ataque com ${data.arma_nome || 'Arma'}`,
        details: `Acerto: ${data.ataque.roll} + ${data.ataque.bonus} = ${data.ataque.total}${data.ataque.critico ? ' (CRÍTICO!)' : ''}\nDano: ${data.dano.rolagens.join(' + ')} = ${data.dano.total}`,
        total: data.dano.total,
        isCritical: data.ataque.critico,
        isFumble: false
      };
      if (typeof showRollResult === 'function') {
        showRollResult(resultado);
      } else {
        console.error('showRollResult não definida');
        alert('Erro interno: função de exibição não encontrada');
      }
    } else {
      alert(data.erro || 'Erro ao realizar ataque');
    }
  } catch (err) {
    console.error('Erro no ataque:', err);
    alert('Erro de conexão: ' + err.message);
  }
}
    if (target.classList.contains('btn-usar-item')) {
      const res = await fetch(`/personagens/${idPersonagem}/inventario/${id}/usar`, { method: 'POST' });
      const data = await res.json();
      alert(data.mensagem || 'Item utilizado');
      carregarInventario();
    }
    if (target.classList.contains('btn-modificar-item')) {
      const modalMods = document.getElementById('modalMods');
      modalMods.style.display = 'block';
      const listaMods = document.getElementById('listaModsDisponiveis');
      listaMods.innerHTML = 'Carregando...';
      const item = await (await fetch(`/personagens/${idPersonagem}/inventario`)).json().then(it => it.find(i => i.id == id));
      const modsRes = await fetch(`/modificacoes?tipo_item=${item.tipo}`);
      const mods = await modsRes.json();
      listaMods.innerHTML = '';
      for (const mod of [...mods.gerais, ...mods.pessoais]) {
        const btn = document.createElement('button');
        btn.className = 'btn-seta';
        btn.innerText = mod.nome;
        btn.onclick = async () => {
          await fetch('/inventario/item/modificacao', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id_item_personagem: id, id_modificacao: mod.id })
          });
          modalMods.style.display = 'none';
          carregarInventario();
          await recalcularCA();
        };
        listaMods.appendChild(btn);
      }
    }
  });

  // Fechar modais
  document.getElementById('btnFecharModalAdd')?.addEventListener('click', () => {
    document.getElementById('modalAddItem').style.display = 'none';
  });
  document.getElementById('btnFecharModalMods')?.addEventListener('click', () => {
    document.getElementById('modalMods').style.display = 'none';
  });

  async function recalcularCA() {
    const res = await fetch(`/personagens/${idPersonagem}/dadosJson`);
    const dados = await res.json();
    if (dados) atualizarInterface(dados);
  }

  // Inicializar
  atualizarCA();
  carregarInventario();
});
</script>