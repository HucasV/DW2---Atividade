<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="ficha">

  <h2><%= personagem.nome %></h2>

  <div class="topo">
    <% if (personagem.imagem) { %>
      <img src="/uploads/<%= personagem.imagem %>" class="img-ficha">
    <% } %>

    <div class="info">
      <p><strong>Nível:</strong> <%= personagem.nivel %></p>
      <p><strong>XP:</strong> <%= personagem.xp %></p>

      <div class="xp-buttons">
        <form action="/personagens/<%= personagem.id %>/xp/add" method="POST">
          <input type="number" name="xp" placeholder="Adicionar XP">
          <button class="btn-seta" type="submit">+ XP</button>
        </form>
        <form action="/personagens/<%= personagem.id %>/xp/remove" method="POST">
          <input type="number" name="xp" placeholder="Remover XP">
          <button class="btn-seta" type="submit">- XP</button>
        </form>
      </div>

      <!-- VIDA -->
      <div class="vida-container">
        <button class="btn-seta btn-dano" data-acao="dano" data-valor="1">⬅</button>
        <div class="barra-bg">
          <div class="barra-vida" style="width: <%= (personagem.vida_atual / vida_max) * 100 %>%"></div>
          <div class="barra-texto-centralizado">
            <span class="vida-atual-editable" data-id="<%= personagem.id %>" data-max="<%= vida_max %>">
              <%= personagem.vida_atual %>
            </span> / 
            <span class="vida-max-editable" data-id="<%= personagem.id %>">
              <%= vida_max %>
            </span>
          </div>
        </div>
        <button class="btn-seta btn-cura" data-acao="cura" data-valor="1">➡</button>
      </div>

      <!-- SANIDADE -->
      <div class="vida-container">
        <button class="btn-seta btn-dano" data-acao="danoSanidade" data-valor="1">⬅</button>
        <div class="barra-bg">
          <div class="barra-sanidade" style="width: <%= (personagem.sanidade_atual / sanidade_max) * 100 %>%"></div>
          <div class="barra-texto-centralizado">
            <span class="sanidade-atual-editable" data-id="<%= personagem.id %>" data-max="<%= sanidade_max %>">
              <%= personagem.sanidade_atual %>
            </span> / 
            <span class="sanidade-max-editable" data-id="<%= personagem.id %>">
              <%= sanidade_max %>
            </span>
          </div>
        </div>
        <button class="btn-seta btn-cura" data-acao="curaSanidade" data-valor="1">➡</button>
      </div>

    </div> 

    <div class="ca-container">
      <h3>Classe de Armadura (CA)</h3>
      <div class="ca-calc">
        <div class="bloco" style="font-size: 30px; text-align: center;"><strong>CA</strong> <br> <span id="caValor"><%= personagem.ca || 10 %></span></div>
        <div class="ca-item">
          <label>Outros:</label>
          <input type="number" id="bonusOutros" value="<%= personagem.bonus_outros || 0 %>" min="0" step="1">
        </div>
        <div class="ca-resultado">
          <small>(10 + Agilidade + Armadura + Outros)</small>
        </div>
      </div>
    </div>
  </div> 

  <hr>

  <!-- ATRIBUTOS -->
  <h3>Atributos</h3>
  <p>Pontos de atributo disponíveis: <strong id="pontos-atributo-disponiveis"><%= pontos_disponiveis_atributo %></strong> (Total: <%= pontos_totais_atributo %>)</p>
  <div class="atributos-grid">
    <div class="attr" data-atributo="forca">
      <div class="attr-nome">FOR</div>
      <div class="attr-valor"><%= personagem.forca %></div>
      <div class="attr-buttons">
        <button type="button" class="btn-atributo btn-seta btn-roll-atributo" data-atributo="forca" title="Rolar 1d20 + Força">🎲</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="forca" data-op="aumentar" <%= pontos_disponiveis_atributo <= 0 ? 'disabled' : '' %>>+</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="forca" data-op="diminuir" <%= personagem.forca <= 1 ? 'disabled' : '' %>>-</button>
      </div>
    </div>
    <div class="attr" data-atributo="agilidade">
      <div class="attr-nome">AGI</div>
      <div class="attr-valor"><%= personagem.agilidade %></div>
      <div class="attr-buttons">
        <button type="button" class="btn-atributo btn-seta btn-roll-atributo" data-atributo="agilidade" title="Rolar 1d20 + Agilidade">🎲</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="agilidade" data-op="aumentar" <%= pontos_disponiveis_atributo <= 0 ? 'disabled' : '' %>>+</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="agilidade" data-op="diminuir" <%= personagem.agilidade <= 1 ? 'disabled' : '' %>>-</button>
      </div>
    </div>
    <div class="attr" data-atributo="constituicao">
      <div class="attr-nome">CON</div>
      <div class="attr-valor"><%= personagem.constituicao %></div>
      <div class="attr-buttons">
        <button type="button" class="btn-atributo btn-seta btn-roll-atributo" data-atributo="constituicao" title="Rolar 1d20 + Constituição">🎲</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="constituicao" data-op="aumentar" <%= pontos_disponiveis_atributo <= 0 ? 'disabled' : '' %>>+</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="constituicao" data-op="diminuir" <%= personagem.constituicao <= 1 ? 'disabled' : '' %>>-</button>
      </div>
    </div>
    <div class="attr" data-atributo="intelecto">
      <div class="attr-nome">INT</div>
      <div class="attr-valor"><%= personagem.intelecto %></div>
      <div class="attr-buttons">
        <button type="button" class="btn-atributo btn-seta btn-roll-atributo" data-atributo="intelecto" title="Rolar 1d20 + Intelecto">🎲</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="intelecto" data-op="aumentar" <%= pontos_disponiveis_atributo <= 0 ? 'disabled' : '' %>>+</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="intelecto" data-op="diminuir" <%= personagem.intelecto <= 1 ? 'disabled' : '' %>>-</button>
      </div>
    </div>
    <div class="attr" data-atributo="atencao">
      <div class="attr-nome">ATE</div>
      <div class="attr-valor"><%= personagem.atencao %></div>
      <div class="attr-buttons">
        <button type="button" class="btn-atributo btn-seta btn-roll-atributo" data-atributo="atencao" title="Rolar 1d20 + Atenção">🎲</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="atencao" data-op="aumentar" <%= pontos_disponiveis_atributo <= 0 ? 'disabled' : '' %>>+</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="atencao" data-op="diminuir" <%= personagem.atencao <= 1 ? 'disabled' : '' %>>-</button>
      </div>
    </div>
    <div class="attr" data-atributo="estabilidade">
      <div class="attr-nome">EST</div>
      <div class="attr-valor"><%= personagem.estabilidade %></div>
      <div class="attr-buttons">
        <button type="button" class="btn-atributo btn-seta btn-roll-atributo" data-atributo="estabilidade" title="Rolar 1d20 + Estabilidade">🎲</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="estabilidade" data-op="aumentar" <%= pontos_disponiveis_atributo <= 0 ? 'disabled' : '' %>>+</button>
        <button type="button" class="btn-atributo btn-seta" data-atributo="estabilidade" data-op="diminuir" <%= personagem.estabilidade <= 1 ? 'disabled' : '' %>>-</button>
      </div>
    </div>
  </div>

  <hr>

  <h3>Descrição</h3>
  <p><%= personagem.descricao %></p>

  <hr>

  <!-- HABILIDADES -->
  <div class="npc-container">
    <h2 class="npc-nome">Habilidades</h2>
    <p class="npc-nivel">Pontos disponíveis: <span class="highlight"><%= pontos_disponiveis %></span></p>

    <div class="form-habilidade">
      <input type="text" id="novaHabilidadeNome" placeholder="Nome da habilidade" required>
      <textarea id="novaHabilidadeDescricao" placeholder="Descrição (opcional)" rows="2"></textarea>
      <select id="novaHabilidadeTipo">
        <option value="dano">Dano</option>
        <option value="cura">Cura</option>
      </select>
      <select id="novaHabilidadeModo">
        <option value="alvo_unico">Alvo único</option>
        <option value="area">Área</option>
      </select>
      <select id="novaHabilidadeTipoAcao">
        <option value="ativa">Ativa</option>
        <option value="passiva">Passiva</option>
      </select>
      <textarea id="novaHabilidadeEfeito" placeholder="Efeito especial (opcional)" rows="2"></textarea>
      <button type="button" id="btnCriarHabilidade">Criar</button>
    </div>

    <button type="button" id="btnAbrirBiblioteca" class="btn-seta">📚 Biblioteca de Habilidades</button>

    <div id="modalBiblioteca" style="display:none; position:fixed; top:20%; left:30%; background:#0f0f0f; border:1px solid #00ff9c; padding:20px; z-index:1000; width:400px;">
      <h3>Biblioteca de Habilidades</h3>
      <div class="tabs">
        <button id="tabGerais" class="tab-btn ativo">Gerais</button>
        <button id="tabPessoais" class="tab-btn">Pessoais</button>
      </div>
      <div id="listaBiblioteca" style="max-height:300px; overflow-y:auto;"></div>
      <button id="btnFecharModal" class="btn-seta" style="margin-top:10px;">Fechar</button>
    </div>

    <div class="habilidades-lista">
      <% if (habilidades.length === 0) { %>
        <p>Nenhuma habilidade criada.</p>
      <% } else { %>
        <% habilidades.forEach(h => { %>
          <div class="npc-bloco">
            <h3><%= h.nome %> (Nv. <%= h.nivel %>) <span class="valor-habilidade">[<%= h.valor %>]</span></h3>
            <p><strong>Descrição:</strong> <%= h.descricao || '—' %></p>
            <p><strong>Tipo:</strong> <%= h.tipo %> | <strong>Modo:</strong> <%= h.modo %> | <strong>Ação:</strong> <%= h.tipo_acao %></p>
            <p><strong>Custo:</strong> <% if (h.custo_sanidade > 0) { %><%= h.custo_sanidade %> Sanidade<% } else { %>Nenhum<% } %></p>
            <% if (h.efeito) { %>
              <p><strong>Efeito:</strong> <%= h.efeito %></p>
            <% } %>
            <div class="habilidade-buttons">
              <% if (h.nivel > 1) { %>
                <button class="btn-diminuir-habilidade btn-seta" data-id="<%= h.id %>">⬇</button>
              <% } %>
              <% if (pontos_disponiveis > 0 && h.is_upgradeable) { %>
                <button class="btn-upar-habilidade btn-seta" data-id="<%= h.id %>">⬆ Upar</button>
              <% } else if (!h.is_upgradeable) { %>
                <span style="opacity:0.5;">(Fixa)</span>
              <% } else { %>
                <button disabled>Sem pontos</button>
              <% } %>
              <button class="btn-roll-habilidade btn-seta" data-id="<%= h.id %>" data-nome="<%= h.nome %>" data-dano="<%= h.valor %>">🎲 Usar</button>
              <button class="btn-deletar-habilidade btn-seta" data-id="<%= h.id %>">🗑️</button>
              <button class="btn-salvar-biblioteca btn-seta" data-id="<%= h.id %>">📚 Salvar</button>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <hr>

    <!-- INVENTÁRIO -->
    <div class="npc-container">
      <h2 class="npc-nome">Inventário</h2>
      <button type="button" id="btnAdicionarItem" class="btn-seta">+ Novo Item</button>
      <div id="listaInventario" class="inventario-grid">
        <!-- itens serão carregados via JS -->
      </div>
    </div>
  </div>

  <hr>

  <form action="/personagens/<%= personagem.id %>/delete" method="POST">
    <button class="btn-delete" onclick="return confirm('Tem certeza que deseja apagar este personagem?')">
      🗑️ Deletar Personagem
    </button>
  </form>
  <a href="/personagens">⬅ Voltar</a>

</div>

<!-- MODAL DE RESULTADO DE ROLAGEM -->
<div id="rollModal" class="roll-modal" style="display: none;">
  <div class="roll-modal-content">
    <div class="roll-header">
      <h3 id="rollTitle">🎲 Resultado da Rolagem</h3>
      <span class="roll-close">&times;</span>
    </div>
    <div class="roll-body">
      <div class="roll-message" id="rollMessage"></div>
      <div class="roll-details" id="rollDetails"></div>
      <div class="roll-total" id="rollTotal"></div>
    </div>
    <div class="roll-footer">
      <button class="btn-seta roll-close-btn">Fechar</button>
    </div>
  </div>
</div>

<!-- MODAL PARA ADICIONAR ITEM -->
<div id="modalAddItem" style="display:none; position:fixed; top:20%; left:30%; background:#0f0f0f; border:1px solid #00ff9c; padding:20px; z-index:1000; width:400px;">
  <h3>Adicionar Item</h3>
  <select id="tipoItemFiltro">
    <option value="">Todos</option>
    <option value="arma">Arma</option>
    <option value="protecao">Proteção</option>
    <option value="geral">Geral</option>
    <option value="anomalo">Anômalo</option>
  </select>
  <div id="listaItensBiblioteca" style="max-height:200px; overflow-y:auto; margin-top:10px;"></div>
  <button id="btnFecharModalAdd" class="btn-seta">Fechar</button>
</div>

<!-- MODAL PARA MODIFICAÇÕES -->
<div id="modalMods" style="display:none; position:fixed; top:20%; left:30%; background:#0f0f0f; border:1px solid #00ff9c; padding:20px; z-index:1000; width:400px;">
  <h3>Modificações</h3>
  <div id="listaModsDisponiveis" style="max-height:200px; overflow-y:auto;"></div>
  <button id="btnFecharModalMods" class="btn-seta">Fechar</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('DOM carregado - script inicializado');

  let salvando = false;
  const idPersonagem = <%= personagem.id %>;

  // ======================
  // FUNÇÃO PARA ATUALIZAR CA
  // ======================
  function atualizarCA() {
    const agilidadeSpan = document.querySelector('.attr[data-atributo="agilidade"] .attr-valor');
    const agilidade = agilidadeSpan ? parseInt(agilidadeSpan.innerText) : 0;
    const bonusArmadura = parseInt(document.getElementById('bonusArmadura')?.value) || 0;
    const bonusOutros = parseInt(document.getElementById('bonusOutros')?.value) || 0;
    const ca = 10 + agilidade + bonusArmadura + bonusOutros;
    const caSpan = document.getElementById('caValor');
    if (caSpan) caSpan.innerText = ca;
  }

  // ======================
  // SALVAR VIDA E SANIDADE
  // ======================
  async function salvarVida(id, campo, valor) {
    if (salvando) return;
    salvando = true;
    try {
      const response = await fetch(`/personagens/${id}/editarVidaJson`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ [campo]: valor })
      });
      const data = await response.json();
      if (response.ok && data.ok) {
        const resDados = await fetch(`/personagens/${id}/dadosJson`);
        const novosDados = await resDados.json();
        if (resDados.ok) atualizarInterface(novosDados);
      } else {
        alert('Erro ao salvar vida: ' + (data.erro || 'Falha'));
      }
    } catch (err) {
      alert('Erro de conexão (vida)');
    } finally {
      salvando = false;
    }
  }

  async function salvarSanidade(id, campo, valor) {
    if (salvando) return;
    salvando = true;
    try {
      const response = await fetch(`/personagens/${id}/editarSanidadeJson`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ [campo]: valor })
      });
      const data = await response.json();
      if (response.ok && data.ok) {
        const resDados = await fetch(`/personagens/${id}/dadosJson`);
        const novosDados = await resDados.json();
        if (resDados.ok) atualizarInterface(novosDados);
      } else {
        alert('Erro ao salvar sanidade: ' + (data.erro || 'Falha'));
      }
    } catch (err) {
      alert('Erro de conexão (sanidade)');
    } finally {
      salvando = false;
    }
  }

  // ======================
  // ATUALIZAR INTERFACE
  // ======================
  window.atualizarInterface = function(dados) {
    const vidaAtualSpan = document.querySelector('.vida-atual-editable');
    const vidaMaxSpan = document.querySelector('.vida-max-editable');
    if (vidaAtualSpan) {
      vidaAtualSpan.innerText = dados.vida_atual;
      vidaAtualSpan.setAttribute('data-max', dados.vida_max);
    }
    if (vidaMaxSpan) vidaMaxSpan.innerText = dados.vida_max;
    const barraVida = document.querySelector('.barra-vida');
    if (barraVida) barraVida.style.width = `${(dados.vida_atual / dados.vida_max) * 100}%`;

    const sanidadeAtualSpan = document.querySelector('.sanidade-atual-editable');
    const sanidadeMaxSpan = document.querySelector('.sanidade-max-editable');
    if (sanidadeAtualSpan) {
      sanidadeAtualSpan.innerText = dados.sanidade_atual;
      sanidadeAtualSpan.setAttribute('data-max', dados.sanidade_max);
    }
    if (sanidadeMaxSpan) sanidadeMaxSpan.innerText = dados.sanidade_max;
    const barraSanidade = document.querySelector('.barra-sanidade');
    if (barraSanidade) barraSanidade.style.width = `${(dados.sanidade_atual / dados.sanidade_max) * 100}%`;

    const pontosAtributoSpan = document.querySelector('#pontos-atributo-disponiveis');
    if (pontosAtributoSpan && dados.pontos_disponiveis_atributo !== undefined) {
      pontosAtributoSpan.innerText = dados.pontos_disponiveis_atributo;
    }
    const caSpan = document.getElementById('caValor');
if (caSpan && dados.ca !== undefined) {
  caSpan.innerText = dados.ca;
}
  };

  // ======================
  // EDITOR IN-PLACE
  // ======================
  function criarEditor(span, tipo, sistema) {
    span.addEventListener('click', function editar(e) {
      e.stopPropagation();
      if (span.querySelector('input')) return;

      const valorAtual = parseInt(span.innerText);
      const id = span.getAttribute('data-id');
      const maxValor = tipo === 'atual' ? parseInt(span.getAttribute('data-max')) : null;

      const input = document.createElement('input');
      input.type = 'number';
      input.value = valorAtual;
      input.classList.add(sistema === 'vida' ? 'editar-vida-input' : 'editar-sanidade-input');
      if (tipo === 'atual') {
        input.min = 0;
        if (maxValor) input.max = maxValor;
      } else {
        input.min = 1;
      }

      span.innerHTML = '';
      span.appendChild(input);
      input.focus();

      function finalizar() {
        let novo = parseInt(input.value);
        if (isNaN(novo)) novo = tipo === 'atual' ? 0 : 1;
        if (tipo === 'atual') {
          if (novo > maxValor) novo = maxValor;
          if (novo < 0) novo = 0;
          if (sistema === 'vida') salvarVida(id, 'vida_atual', novo);
          else salvarSanidade(id, 'sanidade_atual', novo);
        } else {
          if (novo < 1) novo = 1;
          if (sistema === 'vida') salvarVida(id, 'vida_max_custom', novo);
          else salvarSanidade(id, 'sanidade_max_custom', novo);
        }
      }

      input.addEventListener('blur', finalizar);
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') finalizar();
      });
    });
  }

  document.querySelectorAll('.vida-atual-editable').forEach(span => criarEditor(span, 'atual', 'vida'));
  document.querySelectorAll('.vida-max-editable').forEach(span => criarEditor(span, 'max', 'vida'));
  document.querySelectorAll('.sanidade-atual-editable').forEach(span => criarEditor(span, 'atual', 'sanidade'));
  document.querySelectorAll('.sanidade-max-editable').forEach(span => criarEditor(span, 'max', 'sanidade'));

  // ======================
  // DANO / CURA VIA AJAX 
  // ======================
  document.querySelectorAll('.btn-dano, .btn-cura').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const acao = btn.getAttribute('data-acao');
      const valor = parseInt(btn.getAttribute('data-valor')) || 1;
      const id = idPersonagem;

      let url, campo;
      if (acao === 'dano') {
        url = `/personagens/${id}/danoJson`;
        campo = 'dano';
      } else if (acao === 'cura') {
        url = `/personagens/${id}/curaJson`;
        campo = 'cura';
      } else if (acao === 'danoSanidade') {
        url = `/personagens/${id}/danoSanidadeJson`;
        campo = 'dano';
      } else if (acao === 'curaSanidade') {
        url = `/personagens/${id}/curaSanidadeJson`;
        campo = 'cura';
      } else return;

      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ [campo]: valor })
        });
        const data = await response.json();
        if (response.ok && data.ok) {
          const resDados = await fetch(`/personagens/${id}/dadosJson`);
          const novosDados = await resDados.json();
          if (resDados.ok) atualizarInterface(novosDados);
        } else {
          alert(data.erro || 'Erro ao aplicar efeito');
        }
      } catch (err) {
        alert('Erro de conexão');
      }
    });
  });

  // ======================
  // FUNÇÃO PARA SALVAR BÔNUS DA CA
  // ======================
  async function salvarBonus(idPersonagem, bonusArmadura, bonusOutros) {
    try {
      const response = await fetch(`/personagens/${idPersonagem}/atualizarBonus`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bonus_armadura: bonusArmadura, bonus_outros: bonusOutros })
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      if (data.ok) {
        document.getElementById('caValor').innerText = data.ca;
      } else {
        alert(data.erro || 'Erro ao salvar');
      }
    } catch (err) {
      console.error('Erro de conexão:', err);
      alert('Erro de conexão com o servidor');
    }
  }

  // ======================
  // EVENTOS DOS INPUTS DE BÔNUS
  // ======================
  const inputArmadura = document.getElementById('bonusArmadura');
  const inputOutros = document.getElementById('bonusOutros');

  if (inputArmadura && inputOutros) {
    inputArmadura.addEventListener('input', () => {
      const armadura = parseInt(inputArmadura.value) || 0;
      const outros = parseInt(inputOutros.value) || 0;
      salvarBonus(idPersonagem, armadura, outros);
      atualizarCA();
    });

