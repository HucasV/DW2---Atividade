        ${dados.custo_vida > 0 ? `${dados.custo_vida} Vida` : ''}
        ${dados.custo_sanidade > 0 ? `${dados.custo_sanidade} Sanidade` : ''}
        ${(!dados.custo_vida && !dados.custo_sanidade) ? 'Nenhum' : ''}
      </p>
      ${dados.efeito ? `<p><strong>Efeito:</strong> ${dados.efeito}</p>` : ''}
