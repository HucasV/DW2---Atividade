<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="campanhas-container">
  <div class="campanhas-header">
    <h2>Minhas Campanhas</h2>
    <p class="subtitulo">Aqui estão as aventuras das quais você participa</p>
  </div>

  <% if (campanhas.length === 0) { %>
    <div class="sem-campanhas">
      <p>Você não está em nenhuma campanha ainda.</p>
      <p>Peça ao mestre para te adicionar a uma aventura!</p>
    </div>
  <% } else { %>
    <div class="campanhas-grid">
      <% campanhas.forEach(c => { %>
        <div class="card-campanha-jogador">
          <div class="card-header">
            <h3><%= c.nome %></h3>
            <span class="status <%= c.personagens && c.personagens.length ? 'status-ok' : 'status-pendente' %>">
              <%= c.personagens && c.personagens.length ? '✓ Personagem atribuído' : 'Sem personagem' %>
            </span>
          </div>
          <div class="card-body">
            <p class="descricao"><%= c.descricao || 'Sem descrição fornecida.' %></p>
            
            <!-- Cards dos personagens atribuídos -->
            <% if (c.personagens && c.personagens.length) { %>
              <div class="personagens-atribuidos">
                <strong>Personagens nesta campanha:</strong>
                <div class="lista-personagens" style="margin-top: 10px;">
                  <% c.personagens.forEach(p => { %>
                    <div class="card-personagem" style="display: flex; align-items: center; gap: 10px; background: #0a0a0a; padding: 8px; border-radius: 8px; margin-bottom: 8px;">
                      <% if (p.imagem) { %>
                        <img src="/uploads/<%= personagem.imagem %>" class="img-personagem-mini" style="width: 50px; height: 60px; object-fit: cover; border-radius: 6px;">
                      <% } else { %>
                        <div style="width: 50px; height: 60px; background: #111; border: 1px solid #00ff9c; border-radius: 6px;"></div>
                      <% } %>
                      <div>
                        <h4 style="margin: 0;"><%= p.nome %></h4>
                        <p style="margin: 0; font-size: 12px;">Nível <%= p.nivel %></p>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <!-- Formulário para atribuir personagem (apenas se houver personagens disponíveis e nenhum atribuído) -->
            <% if (personagensDoJogador && personagensDoJogador.length > 0 && (!c.personagens || c.personagens.length === 0)) { %>
              <form action="/campanhas/<%= c.id %>/escolher-personagem" method="POST" class="form-personagem">
                <div class="select-wrapper">
                  <select name="id_personagem" required>
                    <option value="">Selecione um personagem</option>
                    <% personagensDoJogador.forEach(p => { %>
                      <option value="<%= p.id %>"><%= p.nome %></option>
                    <% }) %>
                  </select>
                </div>
                <button class="btn-seta" type="submit">Atribuir</button>
              </form>
            <% } else if (c.personagens && c.personagens.length > 0) { %>
              <p style="font-size: 12px; color: #00ffaa;">Personagem já atribuído. Para trocar, peça ao mestre.</p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include("partials/footer") %>