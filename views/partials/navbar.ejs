<nav>
  <ul>
    <img src="/img/Logo.webp" class="logo">
    <li><a href="/">Home</a></li>
    <li><a href="/personagens">Personagens</a></li>
    <li><a href="/regras">Regras</a></li>
    <% if (user) { %>
      <% if (user.role === 'mestre') { %>
        <li><a href="/campanhas/mestre">Campanhas</a></li>
      <% } else { %>
        <li><a href="/campanhas/jogador">Campanhas</a></li>
      <% } %>
    <% } %>
    <% if (user && user.role === 'jogador') { %>
      <li><a href="/minhas-solicitacoes">Convites</a></li>
    <% } %>
    <li class="perfil-nav">
  <a href="/perfil">
    <% if (user && user.avatar) { %>
      <img src="/uploads/avatars/<%= user.avatar %>" class="avatar-nav" alt="Avatar">
    <% } else { %>
      <img src="/img/avatar-padrao.png" class="avatar-nav" alt="Perfil">
    <% } %>
    <span><%= user ? user.nome : 'Perfil' %></span>
  </a>
</li>
  </ul>
</nav>